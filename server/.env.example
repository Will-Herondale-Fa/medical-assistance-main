PORT=4000
MONGO_URI=mongodb://localhost:27017/medical-assist
# Optional: set true only if you want every sensor sample persisted in DB.
PERSIST_SENSOR_STREAM=false

# Required doctor auth credentials
DOCTOR_EMAIL=doctor@example.com
DOCTOR_PASSWORD=change-this-password
DOCTOR_AUTH_SECRET=replace-with-at-least-16-characters

# Required request authentication secrets
SENSOR_INGEST_SECRET=replace-with-strong-sensor-secret
PRINT_AGENT_SECRET=replace-with-strong-print-agent-secret

# Optional CORS controls (comma-separated). If empty, CORS stays open.
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=
